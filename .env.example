# Copy to backend/.env for local (non-Docker) runs, or supply via your cloud
# provider's secret manager / dashboard in production. NEVER commit real secrets.

# --- Database ---
# SQLite by default (no server needed). For a hosted deploy with a real
# Postgres instance, use something like:
#   DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite+pysqlite:///./dev.db

# --- Auth ---
# Generate a strong value, e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Login rate limiting ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300

# --- Payroll / shift rules ---
DEFAULT_HOURLY_RATE=10.00
OPEN_SHIFT_FLAG_THRESHOLD_HOURS=14

# --- Display / branding ---
BUSINESS_NAME=CK_IN&CK_OUT
MANAGER_NAME=Hpatel
DISPLAY_TIMEZONE=America/New_York

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173

# --- First-boot account bootstrap (production only) ---
# If both are set and no account exists yet, creates your one real login on
# next startup. Set these in your host's dashboard, not in a committed file.
BOOTSTRAP_EMAIL=
BOOTSTRAP_PASSWORD=

# --- Frontend build-time (frontend/.env) ---
# Base URL of the backend API. Leave empty in dev to use the Vite proxy.
VITE_API_BASE=
